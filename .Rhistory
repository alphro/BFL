# Fake tiny example
P <- 3; C <- 2; N <- 5
global_fit <- list(
pi = c(0.6, 0.4),
phi = matrix(c(
0.8, 0.2,
0.3, 0.7,
0.5, 0.5
), nrow = P)
)
X <- matrix(sample(0:1, N * P, replace = TRUE), N, P)
predict_BFL_local(global_fit, X, return_probs = TRUE)
