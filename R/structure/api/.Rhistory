library(LCVA)
library(BFL)
phmrc <- read.csv(system.file("extdata", "phmrc_clean.csv", package = "BFL"),
stringsAsFactors = FALSE)
sites <- c("AP", "Mexico")
d1 <- subset(phmrc, site == sites[1])  # target site AP
d2 <- subset(phmrc, site == sites[2])  # training site Mexico
X1 <- as.matrix(d1[, 1:168]); Y1 <- d1$cause   # target X (and labels if you want)
X2 <- as.matrix(d2[, 1:168]); Y2 <- d2$cause   # training site data
set.seed(123)
# TARGET is AP, so X_target = X1 for BOTH summaries
local_AP_self <- prep_BFL_local_LCVA(
X_train = X1, Y_train = Y1,
X_target = X1,
K = 5, lcva_args = list(Nitr = 1000, thin = 2)
)
local_MX_to_AP <- prep_BFL_local_LCVA(
X_train = X2, Y_train = Y2,
X_target = X1,
K = 5, lcva_args = list(Nitr = 1000, thin = 2)
)
local_summaries <- list(AP = local_AP_self, Mexico = local_MX_to_AP)
global_fit <- run_BFL_global(local_summaries, stan_args = list(iter = 1000, chains = 2, seed = 123))
str(global_fit, max.level = 1)
# Predict on the TARGET site X (AP)
pred1 <- predict_BFL_local(global_fit, X1, return_probs = TRUE)
str(pred1, max.level = 1)
